# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct DB URL (for `node db/apply.mjs` migrations only)
DATABASE_URL=

# AI
ANTHROPIC_API_KEY=

# Stripe (payment processing; not required until billing goes live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STANDARD=

# Public URL (used in transactional links + webhook callbacks)
NEXT_PUBLIC_APP_URL=

# Twilio (SMS + per-user phone number provisioning)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Google OAuth (Workspace, Drive, Gmail)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# QuickBooks Online OAuth
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox

# Resend (platform-level transactional emails: invites, trial warnings)
RESEND_API_KEY=
