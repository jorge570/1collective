# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct DB URL (for `node db/apply.mjs` migrations only)
DATABASE_URL=

# Public URL (used in transactional links + webhook callbacks)
NEXT_PUBLIC_APP_URL=

# CRITICAL: token store encryption key (used by src/lib/integrations/base.ts).
# Generate with: openssl rand -base64 32
INTEGRATION_TOKEN_ENCRYPTION_KEY=

# Stripe (payment processing; required before billing goes live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STANDARD=

# Resend (platform-level transactional emails: invites, trial warnings)
# NOT YET IMPLEMENTED — see PUBLISH_CHECKLIST.md HIGH section.
RESEND_API_KEY=

# AI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Twilio (SMS + per-tenant phone number provisioning, Daniella inbound voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VOICE_WEBHOOK_BASE_URL=

# Vapi (Serana outbound AI calls)
VAPI_PRIVATE_KEY=
VAPI_PUBLIC_KEY=

# Google OAuth (Workspace, Drive, Gmail, Business Profile)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# QuickBooks Online OAuth
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
QBO_ENVIRONMENT=sandbox

# Meta (Facebook + Instagram via Amber)
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=
